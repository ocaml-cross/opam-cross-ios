homepage: "https://ocaml.org"
bug-reports: "https://github.com/ocaml/opam-repository/issues"
available: os = "macos"
depends: [
  "ocaml" {= "5.4.1" & post}
  "base-unix" {post}
  "base-bigarray" {post}
  "base-threads" {post}
  "base-domains" {post}
  "base-nnp" {post}
  "base-effects" {post}
  "conf-ios" {>= "4"}
  "cross-toolchain-wrapper"
]
depopts: [
  "ocaml-option-afl"
  "ocaml-option-bytecode-only"
  "ocaml-option-no-flat-float-array"
  "ocaml-option-flambda"
  "ocaml-option-fp"
  "ocaml-option-no-compression"
  "ocaml-option-leak-sanitizer"
  "ocaml-option-address-sanitizer"
  "ocaml-option-static"
  "ocaml-option-tsan"
  "conf-flambda-ios"
]
conflicts: ["relocatable"]
setenv: CAML_LD_LIBRARY_PATH = "%{lib}%/stublibs"
build: [
  [ "./configure"
    "--target=%{conf-ios:target}%"
    "--prefix=%{prefix}%/ios-sysroot"
    "--without-zstd"
    "--disable-shared"
    "--disable-function-sections"
    "--disable-warn-error"
    "--disable-ocamldoc"
    "--disable-ocamltest"
    "--disable-stdlib-manpages"
    "--disable-dependency-generation"
    "--with-afl" {ocaml-option-afl:installed}
    "--disable-flat-float-array" {ocaml-option-no-flat-float-array:installed}
    "--enable-flambda" {ocaml-option-flambda:installed | conf-flambda-ios:installed}
    "--enable-frame-pointers" {ocaml-option-fp:installed}
    "--enable-tsan" {ocaml-option-tsan:installed}
    "ac_cv_func_system=no"
    "ac_cv_func_getentropy=no"
    "CC=%{conf-ios:target}%-gcc"
    "LD=%{conf-ios:target}%-ld"
    "DIRECT_LD=%{conf-ios:target}%-ld"
  ]
  [ make "-j%{jobs}%" "crossopt" ]
]
install: [
  [ make "installcross" ]
  [ "/bin/sh" "./install.sh" "%{prefix}%" ]
]
remove: [
  [ "/bin/sh" "./remove.sh" "%{prefix}%" ]
]
build-env: [
  [MSYS2_ARG_CONV_EXCL = "*"]
  [LSAN_OPTIONS = "detect_leaks=0,exitcode=0"]
  [ASAN_OPTIONS = "detect_leaks=0,exitcode=0"]
]
dev-repo: "git+https://github.com/ocaml/ocaml.git#5.4"
